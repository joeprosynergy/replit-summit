# --------------------------------------------------
# SAFE PLACEHOLDER ENV FOR REFERENCE
# --------------------------------------------------
# This file is intentionally committed.
# Real values live ONLY in Railway/Vercel Environment Variables.
# --------------------------------------------------

# Supabase Configuration
VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_URL=https://your-project.supabase.co

# Server-side only (DO NOT prefix with VITE_)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Optional: Super Admin Email (defaults to joe@summitbuildings.com)
SUPER_ADMIN_EMAIL=admin@example.com
VITE_SUPER_ADMIN_EMAIL=admin@example.com

# Optional: CORS Configuration (comma-separated list of allowed origins)
# In development, localhost is automatically allowed
ALLOWED_ORIGINS=https://yourdomain.com
PUBLIC_URL=https://yourdomain.com
