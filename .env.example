# --------------------------------------------------
# SAFE PLACEHOLDER ENV FOR REFERENCE
# --------------------------------------------------
# This file is intentionally committed.
# Real values live ONLY in Railway Environment Variables.
# --------------------------------------------------

# ── Supabase (client-side, exposed to browser) ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Legacy alias (either works):
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# ── Supabase (server-side only, never exposed to browser) ──
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Cloudinary (server-side only, used by upload/audit API routes) ──
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Site URL (used for sitemap, canonical URLs, OG tags) ──
NEXT_PUBLIC_SITE_URL=https://summitbuildings.com

# ── Optional: Super Admin Email (server-side only, never exposed to browser) ──
SUPER_ADMIN_EMAIL=admin@example.com
